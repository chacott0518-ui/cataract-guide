# 환경변수 예시
# 실제 값은 .env.local에 입력하고 이 파일에는 secret을 넣지 마세요.

# ── 공개 가능 (NEXT_PUBLIC_) ──────────────────────────────

# 사이트 절대 URL (끝 슬래시 없이, canonical·sitemap·OG·JSON-LD 기준)
# - 로컬 개발: http://localhost:3000
# - 운영(권장): https://cataractguide.co.kr
# - Vercel Production Environment Variables에도 동일하게 설정
# - www / *.vercel.app 을 canonical로 쓰지 말 것
NEXT_PUBLIC_SITE_URL=https://cataractguide.co.kr

# 카카오 제휴·문의 링크
NEXT_PUBLIC_KAKAO_AD_URL=http://pf.kakao.com/_DSgxfb/chat

# 모바일 상담전화 (tel: 형식)
NEXT_PUBLIC_CONTACT_PHONE=tel:027395415

# 검색엔진 소유권 인증 (발급 후 입력, 빈 값이면 태그 미출력)
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Supabase 클라이언트용 (상담폼 활성화 시, RLS 검토 필수)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 비공개 (서버 전용, NEXT_PUBLIC_ 금지) ────────────────

# Google Sheets 상담폼 (Apps Script Web App URL)
GOOGLE_SHEETS_WEB_APP_URL=

# Google Sheets shared secret (서버 검증용)
GOOGLE_SHEETS_SHARED_SECRET=

# Supabase service role (서버 전용, 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=
